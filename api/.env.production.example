# EIS Bridge — production API environment (api.eisbridge.com)
# Copy into Forge → Site → Environment for the production API site.
# Never commit real secrets. Generate APP_KEY on the server: php artisan key:generate --show

APP_NAME="EIS Bridge"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.eisbridge.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=warning
LOG_SYSTEM_DB=true
LOG_SYSTEM_DB_LEVEL=warning

# MySQL or PostgreSQL (recommended for production)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eis_bridge_production
DB_USERNAME=forge
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.eisbridge.com

# Admin SPA cookie auth — include API host and marketing/admin origins
SANCTUM_STATEFUL_DOMAINS=api.eisbridge.com,eisbridge.com,www.eisbridge.com
SANCTUM_TOKEN_EXPIRATION=480

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1
PUSHER_SCHEME=https

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_APP_NAME="${APP_NAME}"

FILESYSTEM_DISK=local

# Production requires Redis + Horizon
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@eisbridge.com"
MAIL_FROM_NAME="${APP_NAME}"

CERTIFICATE_DISK=local

# BIR EIS — production transmission (required before go-live)
EIS_SANDBOX_MODE=false
EIS_ENDPOINT=
EIS_TIMEOUT=30
EIS_RETRY_MAX_ATTEMPTS=5
EIS_RETRY_BACKOFF=60,300,900,3600,7200
EIS_MTLS_ENABLED=false
EIS_CLIENT_CERT_PATH=
EIS_CLIENT_KEY_PATH=

OBS_CERT_EXPIRY_WARNING_DAYS=30
OBS_CERT_EXPIRY_CRITICAL_DAYS=7
OBS_ERROR_RATE_THRESHOLD=10
OBS_QUEUE_BACKLOG_THRESHOLD=100
HORIZON_PATH=horizon
ALERTS_ADMIN_EMAIL=ops@eisbridge.com
ALERTS_DEDUPE_HOURS=1

API_KEY_GRACE_HOURS=24
VENDOR_API_RATE_LIMIT=120
VENDOR_TRANSACTION_RATE_LIMIT=60
ADMIN_API_RATE_LIMIT=60
LOGIN_RATE_LIMIT=5

SANDBOX_API_KEY=