# EIS Bridge — sandbox API environment (sandbox.eisbridge.com)
# Copy into Forge → Site → Environment for the sandbox API site.
# Uses a separate database from production. EIS_SANDBOX_MODE must stay true here.

APP_NAME="EIS Bridge Sandbox"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://sandbox.eisbridge.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=info
LOG_SYSTEM_DB=true
LOG_SYSTEM_DB_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eis_bridge_sandbox
DB_USERNAME=forge
DB_PASSWORD=

SESSION_DRIVER=redis
# Requires PHP redis extension (phpredis) on the Forge app server — enable in Server -> PHP -> Extensions.
# REDIS_CLIENT=phpredis is the default; Redis server must be running (redis-cli ping -> PONG).
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=.eisbridge.com

SANCTUM_STATEFUL_DOMAINS=sandbox.eisbridge.com,api.eisbridge.com,eisbridge.com,www.eisbridge.com
SANCTUM_TOKEN_EXPIRATION=480

BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local

QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="sandbox@eisbridge.com"
MAIL_FROM_NAME="${APP_NAME}"

CERTIFICATE_DISK=local

EIS_SANDBOX_MODE=true
EIS_ENDPOINT=https://sandbox.eis.bir.gov.ph/api/v1/invoices
EIS_TIMEOUT=30
EIS_RETRY_MAX_ATTEMPTS=5
EIS_RETRY_BACKOFF=60,300,900,3600,7200
EIS_MTLS_ENABLED=false

OBS_CERT_EXPIRY_WARNING_DAYS=30
OBS_CERT_EXPIRY_CRITICAL_DAYS=7
OBS_ERROR_RATE_THRESHOLD=10
OBS_QUEUE_BACKLOG_THRESHOLD=100
HORIZON_PATH=horizon
ALERTS_ADMIN_EMAIL=ops@eisbridge.com
ALERTS_DEDUPE_HOURS=1

API_KEY_GRACE_HOURS=24
VENDOR_API_RATE_LIMIT=120
VENDOR_TRANSACTION_RATE_LIMIT=60
ADMIN_API_RATE_LIMIT=60
LOGIN_RATE_LIMIT=5

SANDBOX_API_KEY=