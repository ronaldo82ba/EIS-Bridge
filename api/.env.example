APP_NAME="EIS Bridge"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting: log (dev), pusher (realtime), or null (disabled)
BROADCAST_CONNECTION=log
# Legacy alias — Laravel reads BROADCAST_CONNECTION; set both to the same value if needed
BROADCAST_DRIVER=log

# Pusher (https://pusher.com — free tier works for dev)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Vite exposes these to the admin SPA (must match PUSHER_APP_KEY / cluster)
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
FILESYSTEM_DISK=local
# Phase 2 queues: database (Windows/local dev) or redis (production + Horizon)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SANDBOX_API_KEY=VENDOR_API_KEY_123

# Observability thresholds
OBS_CERT_EXPIRY_WARNING_DAYS=30
OBS_CERT_EXPIRY_CRITICAL_DAYS=7
OBS_ERROR_RATE_THRESHOLD=10
OBS_QUEUE_BACKLOG_THRESHOLD=100
HORIZON_PATH=horizon
LOG_SYSTEM_DB=true
LOG_SYSTEM_DB_LEVEL=warning

# Certificate expiry alerts (admin email for PKI notifications)
ALERTS_ADMIN_EMAIL=admin@eis-bridge.test

# EIS transmission (Phase 2)
# Sandbox URL (default). Production: use the endpoint from your BIR EIS registration package.
EIS_ENDPOINT=https://sandbox.eis.bir.gov.ph/api/v1/invoices
EIS_TIMEOUT=30
# true = simulated transmission + sandbox signing fallback (local dev default)
# false = real HTTP POST to EIS_ENDPOINT (production)
EIS_SANDBOX_MODE=true
EIS_RETRY_MAX_ATTEMPTS=5
EIS_RETRY_BACKOFF=60,300,900,3600,7200
# Optional mutual TLS (production, when required by BIR)
EIS_MTLS_ENABLED=false
EIS_CLIENT_CERT_PATH=
EIS_CLIENT_KEY_PATH=

# Phase 2 queue workers
# Local/Windows: QUEUE_CONNECTION=database then:
#   php artisan queue:work database --queue=mapping,signing,transmission,retry,webhooks
# Production: QUEUE_CONNECTION=redis then:
#   php artisan horizon
# Horizon supervises mapping, signing, transmission, retry, and webhooks queues (see config/horizon.php).

# Security (Phase 5)
API_KEY_GRACE_HOURS=24
VENDOR_API_RATE_LIMIT=120
VENDOR_TRANSACTION_RATE_LIMIT=60
ADMIN_API_RATE_LIMIT=60
LOGIN_RATE_LIMIT=5
CERTIFICATE_DISK=local
SANCTUM_TOKEN_EXPIRATION=480
